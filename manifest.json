{
  "manifest_version": 3,
  "name": "SiteLocker",
  "version": "1.0.0",
  "description": "A premium site lock utility. Lock distracting or sensitive domains behind a secure 4-digit PIN.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["js/security.js", "audio/audio.js", "js/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["css/content.css"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
